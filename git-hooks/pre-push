#!/usr/bin/env bash
# pre-push hook — Only publish.py may push.
#
# publish.py sets PSS_PUBLISH_GATE=1 before calling git push.
# If that env var is missing, this hook blocks the push.
#
# To bypass (NOT RECOMMENDED): git push --no-verify

set -euo pipefail

if [ "${PSS_PUBLISH_GATE:-}" != "1" ]; then
    echo ""
    echo "ERROR: Direct git push is blocked."
    echo ""
    echo "All pushes MUST go through the release pipeline:"
    echo "  uv run python scripts/publish.py --bump patch"
    echo ""
    exit 1
fi
