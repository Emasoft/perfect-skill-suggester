#!/usr/bin/env bash
# pre-push hook — Delegates to pss_ship.py --gate for validation.
#
# Blocks push if CRITICAL, MAJOR, or MINOR issues are found.
# NITs are treated as warnings and do NOT block.
#
# To install:
#   uv run python scripts/pss_ship.py --install-hook
#   # or manually:
#   cp git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# To bypass (NOT RECOMMENDED):
#   git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if command -v uv &> /dev/null; then
    uv run python scripts/pss_ship.py --gate
else
    python3 scripts/pss_ship.py --gate
fi
exit $?
