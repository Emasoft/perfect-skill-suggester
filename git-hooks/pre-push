#!/usr/bin/env bash
# NOTE: CPV reports RC-PIPELINE-DRIFT-001 against this hook. The divergence
# from the canonical CPV pre-push is deliberate: PSS adds a process-tree
# ancestry check (Layer 1) that blocks direct `git push` invocations. The
# canonical hook only runs `publish.py --gate` (our Layer 2), which means
# raw `git push` would still pass without a publish.py ancestor. PSS's
# release rule mandates ALL pushes go through publish.py, so we keep both
# layers. Last reviewed: 2026-05-17.
#
# pre-push hook — Unbypassable gate for every push.
#
# Two enforcement layers:
#   1. Ancestry check: walks the process tree and fails if publish.py
#      is NOT an ancestor. This blocks direct `git push` calls.
#   2. Gate re-run: runs publish.py --gate (lint + tests + validate)
#      unconditionally. Even if the ancestry check passes, the gate
#      runs again — redundant is fine, a bypass is not.
#
# No env var check exists. No "trusted caller" marker. No exceptions.
# The only way to bypass is `git push --no-verify`, a git built-in
# outside this hook's control.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ---- Layer 1: ancestry check ----
if ! command -v ps &> /dev/null; then
    echo "ERROR: 'ps' is not available. Cannot verify caller ancestry."
    exit 1
fi

pid=$$
found_publish=0
hops=0
while [ "$pid" -gt 1 ] && [ "$hops" -lt 32 ]; do
    ppid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || echo "")
    if [ -z "$ppid" ] || [ "$ppid" = "0" ]; then
        break
    fi
    pcmd=$(ps -o command= -p "$ppid" 2>/dev/null || echo "")
    # Match either the script path (scripts/publish.py) or the module name
    # when invoked via `uv run python scripts/publish.py ...`
    if echo "$pcmd" | grep -qE '(^|/| )(scripts/)?publish\.py( |$)'; then
        found_publish=1
        break
    fi
    pid="$ppid"
    hops=$((hops + 1))
done

if [ "$found_publish" -eq 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ERROR: Direct git push is forbidden.                        ║"
    echo "║                                                              ║"
    echo "║  All pushes MUST go through the release pipeline:            ║"
    echo "║     uv run python scripts/publish.py                         ║"
    echo "║                                                              ║"
    echo "║  The pipeline enforces lint + tests + validation with        ║"
    echo "║  0 issues before any commit is pushed to GitHub.             ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

# ---- Layer 2: re-run the full gate unconditionally ----
if command -v uv &> /dev/null; then
    uv run python scripts/publish.py --gate
else
    python3 scripts/publish.py --gate
fi
