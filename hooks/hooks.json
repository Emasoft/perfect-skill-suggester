{
  "description": "Perfect Skill Suggester - AI-powered skill activation with 88%+ accuracy",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --quiet --script \"${CLAUDE_PLUGIN_ROOT}/scripts/pss_hook.py\"",
            "timeout": 10,
            "statusMessage": "Analyzing skill triggers..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --quiet --script \"${CLAUDE_PLUGIN_ROOT}/scripts/pss_hook.py\" --warm-index &",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --quiet --script \"${CLAUDE_PLUGIN_ROOT}/scripts/pss_hook.py\" --post-compact",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
